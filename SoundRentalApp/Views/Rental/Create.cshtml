@model SoundRentalApp.ViewModels.RentalViewModel
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Rental Transaction";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-primary text-white">
            <h4>Rental Transaction</h4>
        </div>

        <div class="card-body">

            <form asp-action="Create" method="post">

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="row mb-3">

                    <div class="col-md-4">
                        <label asp-for="RentalNumber" class="form-label"></label>
                        <input asp-for="RentalNumber" class="form-control" readonly />
                    </div>

                    <div class="col-md-4">
                        <label asp-for="RentalDate" class="form-label"></label>
                        <input asp-for="RentalDate" type="date" class="form-control" />
                    </div>

                    <div class="col-md-4">
                        <label asp-for="ReturnDate" class="form-label"></label>
                        <input asp-for="ReturnDate" type="date" class="form-control" />
                    </div>

                </div>

                <div class="mb-4">

                    <label asp-for="CustomerId" class="form-label"></label>

                    <select asp-for="CustomerId"
                            asp-items="ViewBag.CustomerList"
                            class="form-select">

                        <option value="">-- Select Customer --</option>

                    </select>

                </div>

                <hr />

                <div class="d-flex justify-content-between align-items-center mb-3">

                    <h5>Equipment List</h5>

                    <button type="button"
                            id="btnAdd"
                            class="btn btn-success">

                        Add Equipment

                    </button>

                </div>

                <div class="table-responsive">

                    <table class="table table-bordered table-hover">

                        <thead class="table-dark">

                            <tr>

                                <th>Equipment</th>
                                <th width="90">Stock</th>
                                <th width="140">Price</th>
                                <th width="90">Qty</th>
                                <th width="160">Subtotal</th>
                                <th width="80">Action</th>

                            </tr>

                        </thead>

                        <tbody id="detailBody">
                        </tbody>

                    </table>

                </div>

                <hr />

                <div class="row">

                    <div class="col-md-4">

                        <label asp-for="DownPayment"></label>

                        <input asp-for="DownPayment"
                               class="form-control" />

                    </div>

                    <div class="col-md-4">

                        <label asp-for="GrandTotal"></label>

                        <input asp-for="GrandTotal"
                               class="form-control"
                               readonly />

                    </div>

                    <div class="col-md-4">

                        <label asp-for="RemainingPayment"></label>

                        <input asp-for="RemainingPayment"
                               class="form-control"
                               readonly />

                    </div>

                </div>

                <div class="mt-4">

                    <button type="submit"
                            class="btn btn-primary">

                        Save Transaction

                    </button>

                    <a asp-action="Index"
                       class="btn btn-secondary">

                        Back

                    </a>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts{

    <partial name="_ValidationScriptsPartial" />

    <script>

        let index = 0;

        const equipmentOptions =
        `@Html.Raw(string.Join("", ((IEnumerable<SelectListItem>)ViewBag.EquipmentList)
        .Select(x => $"<option value='{x.Value}'>{x.Text}</option>")))`;

        document.getElementById("btnAdd").addEventListener("click", function () {

            let row = `

            <tr>

                <td>

                    <select class="form-select equipment"
                            name="Items[${index}].EquipmentId">

                        <option value="">Select Equipment</option>

                        ${equipmentOptions}

                    </select>

                </td>

                <td>

                    <input class="form-control stock"
                           readonly />

                </td>

                <td>

                    <input class="form-control price"
                           readonly />

                </td>

                <td>

                    <input type="number"
                           class="form-control qty"
                           name="Items[${index}].Qty"
                           value="1"
                           min="1" />

                </td>

                <td>

                    <input class="form-control subtotal"
                           readonly />

                </td>

                <td>

                    <button type="button"
                            class="btn btn-danger remove">

                        X

                    </button>

                </td>

            </tr>`;

            document
                .getElementById("detailBody")
                .insertAdjacentHTML("beforeend", row);

            index++;

        });

        document.addEventListener("change", async function (e) {

            if (!e.target.classList.contains("equipment"))
                return;

            let row = e.target.closest("tr");

            let id = e.target.value;

            if (id === "")
                return;

            let response =
                await fetch("/Equipment/GetEquipment?id=" + id);

            let data =
                await response.json();

            row.querySelector(".stock").value = data.stock;

            row.querySelector(".price").value = data.price;

            calculate(row);

        });

        document.addEventListener("input", function (e) {

            if (e.target.classList.contains("qty")) {

                calculate(
                    e.target.closest("tr"));

            }

            if (e.target.id === "DownPayment") {

                calculateGrandTotal();

            }

        });

        document.addEventListener("click", function (e) {

            if (e.target.classList.contains("remove")) {

                e.target.closest("tr").remove();

                calculateGrandTotal();

            }

        });

        function calculate(row) {

            let qty =
                Number(row.querySelector(".qty").value);

            let stock =
                Number(row.querySelector(".stock").value);

            if (qty > stock) {

                alert("Quantity exceeds available stock.");

                row.querySelector(".qty").value = stock;

                qty = stock;

            }

            let price =
                Number(row.querySelector(".price").value);

            let subtotal = qty * price;

            row.querySelector(".subtotal").value = subtotal;

            calculateGrandTotal();

        }

        function calculateGrandTotal() {

            let total = 0;

            document.querySelectorAll(".subtotal")
                .forEach(function (item) {

                    total += Number(item.value);

                });

            document.getElementById("GrandTotal").value = total;

            let dp =
                Number(document.getElementById("DownPayment").value);

            document.getElementById("RemainingPayment").value =
                total - dp;

        }

    </script>

}
