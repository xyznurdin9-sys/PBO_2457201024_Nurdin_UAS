@model SoundRentalApp.ViewModels.EquipmentViewModel

@{
    ViewData["Title"] = "Edit Equipment";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-warning text-dark">

            <h4>Edit Equipment</h4>

        </div>

        <div class="card-body">

            <form asp-action="Edit" method="post" enctype="multipart/form-data">

                <input asp-for="Id" type="hidden" />
                <input asp-for="Image" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">

                    <div class="col-md-6">

                        <div class="mb-3">

                            <label asp-for="EquipmentCode" class="form-label"></label>

                            <input asp-for="EquipmentCode"
                                   class="form-control"
                                   readonly />

                        </div>

                        <div class="mb-3">

                            <label asp-for="EquipmentName" class="form-label"></label>

                            <input asp-for="EquipmentName"
                                   class="form-control" />

                            <span asp-validation-for="EquipmentName" class="text-danger"></span>

                        </div>

                        <div class="mb-3">

                            <label asp-for="CategoryId" class="form-label"></label>

                            <select asp-for="CategoryId"
                                    asp-items="ViewBag.CategoryList"
                                    class="form-select">
                            </select>

                        </div>

                        <div class="mb-3">

                            <label asp-for="Brand" class="form-label"></label>

                            <input asp-for="Brand"
                                   class="form-control" />

                        </div>

                    </div>

                    <div class="col-md-6">

                        <div class="mb-3">

                            <label asp-for="RentalPrice" class="form-label"></label>

                            <input asp-for="RentalPrice"
                                   class="form-control" />

                        </div>

                        <div class="mb-3">

                            <label asp-for="Stock" class="form-label"></label>

                            <input asp-for="Stock"
                                   class="form-control" />

                        </div>

                        <div class="mb-3">

                            <label asp-for="Condition" class="form-label"></label>

                            <select asp-for="Condition" class="form-select">

                                <option>Good</option>
                                <option>Minor Damage</option>
                                <option>Heavy Damage</option>

                            </select>

                        </div>

                        <div class="mb-3">

                            <label asp-for="Status" class="form-label"></label>

                            <select asp-for="Status" class="form-select">

                                <option>Available</option>
                                <option>Unavailable</option>

                            </select>

                        </div>

                    </div>

                </div>

                @if (!string.IsNullOrEmpty(Model.Image))
                {
                    <div class="mb-3">

                        <label class="form-label">Current Image</label>

                        <br />

                        <img src="~/uploads/@Model.Image"
                             width="200"
                             class="img-thumbnail" />

                    </div>
                }

                <div class="mb-3">

                    <label asp-for="ImageFile" class="form-label"></label>

                    <input asp-for="ImageFile"
                           class="form-control" />

                </div>

                <button class="btn btn-warning">

                    Update

                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">

                    Back

                </a>

            </form>

        </div>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}