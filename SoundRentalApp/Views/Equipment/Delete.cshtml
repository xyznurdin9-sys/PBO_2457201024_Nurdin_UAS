@model SoundRentalApp.Models.Equipment

@{
    ViewData["Title"] = "Delete Equipment";
}

<div class="container mt-4">

    <div class="card border-danger shadow">

        <div class="card-header bg-danger text-white">

            <h4>Delete Equipment</h4>

        </div>

        <div class="card-body">

            <div class="alert alert-danger">

                <h5>Are you sure you want to delete this equipment?</h5>

            </div>

            <table class="table table-bordered">

                <tr>

                    <th width="35%">Equipment Code</th>

                    <td>@Model.EquipmentCode</td>

                </tr>

                <tr>

                    <th>Equipment Name</th>

                    <td>@Model.EquipmentName</td>

                </tr>

                <tr>

                    <th>Category</th>

                    <td>@Model.Category?.CategoryName</td>

                </tr>

                <tr>

                    <th>Brand</th>

                    <td>@Model.Brand</td>

                </tr>

                <tr>

                    <th>Rental Price</th>

                    <td>Rp @Model.RentalPrice.ToString("N0")</td>

                </tr>

            </table>

            <form asp-action="Delete">

                <input type="hidden"
                       asp-for="Id" />

                <button type="submit"
                        class="btn btn-danger">

                    Delete

                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">

                    Cancel

                </a>

            </form>

        </div>

    </div>

</div>