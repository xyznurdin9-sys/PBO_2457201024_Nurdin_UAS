@{
    ViewData["Title"] = "Report";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-success text-white">

            <h3>
                <i class="bi bi-file-earmark-bar-graph"></i>
                Report Menu
            </h3>

        </div>

        <div class="card-body">

            <div class="row g-4">

                <div class="col-md-4">

                    <div class="card border-primary shadow-sm">

                        <div class="card-body text-center">

                            <i class="bi bi-calendar-day display-4 text-primary"></i>

                            <h5 class="mt-3">Daily Report</h5>

                            <p class="text-muted">
                                Rental transactions today.
                            </p>

                            <a asp-action="Daily"
                               class="btn btn-primary w-100">

                                Open

                            </a>

                        </div>

                    </div>

                </div>

                <div class="col-md-4">

                    <div class="card border-success shadow-sm">

                        <div class="card-body text-center">

                            <i class="bi bi-calendar-month display-4 text-success"></i>

                            <h5 class="mt-3">Monthly Report</h5>

                            <p class="text-muted">
                                Monthly rental transactions.
                            </p>

                            <a asp-action="Monthly"
                               class="btn btn-success w-100">

                                Open

                            </a>

                        </div>

                    </div>

                </div>

                <div class="col-md-4">

                    <div class="card border-danger shadow-sm">

                        <div class="card-body text-center">

                            <i class="bi bi-calendar3 display-4 text-danger"></i>

                            <h5 class="mt-3">Yearly Report</h5>

                            <p class="text-muted">
                                Annual rental summary.
                            </p>

                            <a asp-action="Yearly"
                               class="btn btn-danger w-100">

                                Open

                            </a>

                        </div>

                    </div>

                </div>

                <div class="col-md-6">

                    <div class="card border-info shadow-sm">

                        <div class="card-body text-center">

                            <i class="bi bi-people-fill display-4 text-info"></i>

                            <h5 class="mt-3">Customer Report</h5>

                            <p class="text-muted">
                                Customer rental history.
                            </p>

                            <a asp-action="Customer"
                               class="btn btn-info w-100 text-white">

                                Open

                            </a>

                        </div>

                    </div>

                </div>

                <div class="col-md-6">

                    <div class="card border-warning shadow-sm">

                        <div class="card-body text-center">

                            <i class="bi bi-speaker-fill display-4 text-warning"></i>

                            <h5 class="mt-3">Equipment Report</h5>

                            <p class="text-muted">
                                Equipment inventory and stock.
                            </p>

                            <a asp-action="Equipment"
                               class="btn btn-warning w-100">

                                Open

                            </a>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>