@model IEnumerable<SoundRentalApp.Models.RentalHeader>

@{
    ViewData["Title"] = "Daily Report";
    decimal total = Model.Sum(x => x.GrandTotal);
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-success text-white">

            <h3>
                <i class="bi bi-calendar-day"></i>
                Daily Rental Report
            </h3>

        </div>

        <div class="card-body">

            <form method="get" class="row mb-4">

                <div class="col-md-3">

                    <input type="date" name="date" value="@(((DateTime)ViewBag.Date).ToString("yyyy-MM-dd"))"
                           class="form-control" />

                </div>

                <div class="col-md-2">

                    <button class="btn btn-success">

                        <i class="bi bi-search"></i>

                        Filter

                    </button>

                </div>

            </form>
            <div class="d-flex justify-content-between mb-3">

                <h3>Daily Rental Report</h3>

                <div>

                    <a asp-action="DailyPdf" asp-route-date="@ViewBag.Date" class="btn btn-danger">

                        <i class="bi bi-file-earmark-pdf"></i>
                        Export PDF

                    </a>

                    <a asp-action="DailyExcel" asp-route-date="@ViewBag.Date" class="btn btn-success">

                        <i class="bi bi-file-earmark-excel"></i>
                        Export Excel

                    </a>

                </div>

            </div>

            <table class="table table-bordered table-hover">

                <thead class="table-success">

                    <tr>

                        <th>No</th>
                        <th>Rental No</th>
                        <th>Customer</th>
                        <th>Rental Date</th>
                        <th>Return Date</th>
                        <th>Status</th>
                        <th class="text-end">Grand Total</th>

                    </tr>

                </thead>

                <tbody>

                    @{
                        int no = 1;
                    }

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>@no</td>

                            <td>@item.RentalNumber</td>

                            <td>@item.Customer?.CustomerName</td>

                            <td>@item.RentalDate.ToString("dd/MM/yyyy")</td>

                            <td>@item.ReturnDate.ToString("dd/MM/yyyy")</td>

                            <td>

                                @if (item.Status == "Booked")
                                {
                                    <span class="badge bg-warning">
                                        Booked
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-success">
                                        Returned
                                    </span>
                                }

                            </td>

                            <td class="text-end">

                                Rp @item.GrandTotal.ToString("N0")

                            </td>

                        </tr>

                        no++;
                    }

                </tbody>

                <tfoot class="table-light">

                    <tr>

                        <th colspan="6" class="text-end">

                            Total Revenue

                        </th>

                        <th class="text-end">

                            Rp @total.ToString("N0")

                        </th>

                    </tr>

                </tfoot>

            </table>

        </div>

    </div>

</div>